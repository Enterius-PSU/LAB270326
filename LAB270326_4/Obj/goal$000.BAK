/* 
 * ????????? ??? ???????????, ?? ?????? ?????? ??????? ?????? ???????.
 * ??????? ???????? ?? ???????? ???? ???????????? ??????? ? ???????? ???????.
 */

DOMAINS
    city = string
    citylist = city*

PREDICATES
    nondeterm permutation(citylist, citylist)  % ????????? ???? ????????????
    nondeterm select(city, citylist, citylist) % ????? ???????? ?? ??????
    nondeterm solve                            % ??????? ???????? ???????
    nondeterm check1(city, city)               % ??????? 1
    nondeterm check2(city, city)               % ??????? 2
    nondeterm check3(city, city)               % ??????? 3
    nondeterm check4(city, city)               % ??????? 4

CLAUSES
    % select(X, List, NewList) – ???????? ??????? X ?? ?????? List,
    % ?????????? ?????? NewList ??? X.
    select(X, [X|Tail], Tail).
    select(X, [Y|Tail], [Y|Rest]) :-
        select(X, Tail, Rest).

    % permutation(List, Perm) – Perm – ???????????? ????????? List.
    permutation([], []).
    permutation(List, [X|Perm]) :-
        select(X, List, Rest),
        permutation(Rest, Perm).

    % ??????? ??????:
    % 1) ???? ???? ?? ?? ?????, ?? ???? ?? ???????????.
    check1(City1, City2) :-
        City1 = "?????"; City2 = "??????????".

    % 2) ??? ????, ??? ???? ???????? ?? ????????.
    check2(City2, City3) :-
        City2 = "???????"; City3 = "???????".

    % 3) ???? ???? ?? ?? ?????????, ?? ???? ???????? ?? ????????.
    check3(City3, City4) :-
        City3 = "????????"; City4 = "???????".

    % 4) ??? ???? ???????? ?? ?????, ??? ???? ?? ???????????.
    check4(City5, City4) :-
        City5 = "?????"; City4 = "??????????".

    % ??????? ??????:
    solve :-
        Cities = ["???????", "?????", "???????", "????????", "??????????"],
        % ?????????? ???????????? ???????, ??????????? ?? ?????:
        % City1 – ????, City2 – ????, City3 – ????, City4 – ????, City5 – ????.
        permutation(Cities, [City1, City2, City3, City4, City5]),
        % ????????? ??? ???????
        check1(City1, City2),
        check2(City2, City3),
        check3(City3, City4),
        check4(City5, City4),
        % ????? ??????????:
        write("???? ?? ", City1), nl,
        write("???? ?? ", City2), nl,
        write("???? ?? ", City3), nl,
        write("???? ?? ", City4), nl,
        write("???? ?? ", City5), nl.

GOAL
    solve.




